# Python cache and virtual environments
__pycache__/
*.py[cod]
.pytest_cache/
.venv/

# Android/Gradle local artifacts
.gradle/
android/.gradle/
android/local.properties
android/**/build/

# IDE
.idea/
.vscode/

# Environment files
.env
backend/.env

# Built APKs: ignore stray builds at the repo root, but keep the curated
# judge-ready APK that lives in dist/ tracked so reviewers always have one
# without needing to run CI.
*.apk
!dist/*.apk
