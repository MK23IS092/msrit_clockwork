# Python cache and virtual environments
__pycache__/
*.py[cod]
.pytest_cache/
.venv/

# Android/Gradle local artifacts
.gradle/
android/.gradle/
android/local.properties
android/**/build/

# Backend runtime artefacts (generated when pipelines actually run)
backend/data/pipeline_runs/
backend/data/*.db
backend/data/*.sqlite
backend/data/*.sqlite3

# Local-only git history rewrite helper (never commit)
.git_rewrite_env.sh

# IDE
.idea/
.vscode/

# Environment files
.env
backend/.env

# Built APKs: ignore stray builds at the repo root, but keep the curated
# judge-ready APK that lives in dist/ tracked so reviewers always have one
# without needing to run CI.
*.apk
!dist/*.apk
