# Prevent Windows checkouts from converting LF to CRLF on shell scripts.
# Linux refuses to exec a script whose shebang ends in \r ("required file
# not found"), so we pin all unix-style scripts to LF.
* text=auto eol=lf

# Explicitly LF for shell scripts and gradle wrappers so they always run
# on Linux/macOS regardless of the contributor's OS.
*.sh        text eol=lf
gradlew     text eol=lf
gradlew.bat text eol=crlf

# Treat known binary blobs as binary so git doesn't try to munge them.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.jar       binary
*.apk       binary
*.aab       binary
*.docx      binary
*.pptx      binary
*.xlsx      binary
*.mp4       binary
*.mov       binary
*.webm      binary
